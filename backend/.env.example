# License Management System - Backend Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
MONGO_URL=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/DATABASE_NAME
DB_NAME=license_management

# Security
SECRET_KEY=your-super-secret-jwt-key-here-generate-a-strong-one
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration (CRITICAL: Do not use * in production with credentials)
# Add your actual frontend domains, separated by commas
CORS_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com,http://localhost:3000

# Timezone
TZ=America/Recife

# WhatsApp Service (optional)
WHATSAPP_SERVICE_URL=http://localhost:3001

# Redis (optional - for advanced session management)
REDIS_URL=redis://localhost:6379

# Environment
ENVIRONMENT=development