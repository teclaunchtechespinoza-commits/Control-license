 export const API_BASE = process.env.REACT_APP_API_BASE || "http://localhost:8000";
 
+async function jsonFetch(url, opts = {}) {
+  const res = await fetch(url, {
+    headers: {
+      "Content-Type": "application/json",
+      ...(opts.headers || {}),
+    },
+    credentials: "include",
+    ...opts,
+  });
+  if (!res.ok) {
+    let msg = `HTTP ${res.status}`;
+    try {
+      const data = await res.json();
+      if (data && data.detail) msg = data.detail;
+    } catch {}
+    throw new Error(msg);
+  }
+  return res.json().catch(() => ({}));
+}
+
 export async function login(email, password) {
   // existente...
 }
+
+// ---------- Sprint 2: Convites ----------
+export async function createInvitation(email) {
+  const body = { email };
+  return jsonFetch(`${API_BASE}/admin/invitations`, {
+    method: "POST",
+    body: JSON.stringify(body),
+  });
+}
+
+export async function acceptInvite(token, password) {
+  const body = { token };
+  if (password) body.password = password;
+  return jsonFetch(`${API_BASE}/auth/accept-invite`, {
+    method: "POST",
+    body: JSON.stringify(body),
+  });
+}
+
+export async function revokeInvitation(token) {
+  const body = token; // endpoint espera body=token simples
+  return jsonFetch(`${API_BASE}/admin/invitations/revoke`, {
+    method: "POST",
+    body: JSON.stringify(body),
+  });
+}
