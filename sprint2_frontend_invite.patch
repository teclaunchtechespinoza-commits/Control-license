@@ -0,0 +1,86 @@
+import React, { useState } from "react";
+import { createInvitation, revokeInvitation } from "../api";
+
+export default function AdminInvitePage() {
+  const [email, setEmail] = useState("");
+  const [inviteLink, setInviteLink] = useState("");
+  const [error, setError] = useState("");
+  const [loading, setLoading] = useState(false);
+  const [revoking, setRevoking] = useState(false);
+
+  const onCreate = async (e) => {
+    e.preventDefault();
+    setError("");
+    setInviteLink("");
+    setLoading(true);
+    try {
+      const resp = await createInvitation(email.trim());
+      setInviteLink(resp?.invite_link || "");
+    } catch (err) {
+      setError(err.message || "Falha ao criar convite");
+    } finally {
+      setLoading(false);
+    }
+  };
+
+  const onRevoke = async () => {
+    if (!inviteLink) return;
+    const url = new URL(inviteLink);
+    const token = url.searchParams.get("token");
+    if (!token) return setError("Token não encontrado no link.");
+    setRevoking(true);
+    setError("");
+    try {
+      await revokeInvitation(token);
+      setInviteLink("");
+    } catch (err) {
+      setError(err.message || "Falha ao revogar convite");
+    } finally {
+      setRevoking(false);
+    }
+  };
+
+  return (
+    <div style={{ maxWidth: 640, margin: "40px auto", padding: 16 }}>
+      <h2>Convites (Admin)</h2>
+      <form onSubmit={onCreate}>
+        <div style={{ margin: "12px 0" }}>
+          <label>E-mail do cliente</label>
+          <input
+            type="email"
+            required
+            placeholder="cliente@empresa.com"
+            value={email}
+            onChange={(e) => setEmail(e.target.value)}
+            style={{ width: "100%", padding: 8 }}
+          />
+        </div>
+        {error && <div style={{ color: "crimson", marginBottom: 8 }}>{error}</div>}
+        <button type="submit" disabled={loading}>
+          {loading ? "Enviando..." : "Gerar convite"}
+        </button>
+      </form>
+
+      {inviteLink && (
+        <div style={{ marginTop: 16, padding: 12, background: "#f4f7ff", border: "1px solid #d7e3ff" }}>
+          <div><strong>Link de convite:</strong></div>
+          <div style={{ wordBreak: "break-all" }}>{inviteLink}</div>
+          <div style={{ marginTop: 8 }}>
+            <button onClick={onRevoke} disabled={revoking}>
+              {revoking ? "Revogando..." : "Revogar convite"}
+            </button>
+          </div>
+        </div>
+      )}
+    </div>
+  );
+}
