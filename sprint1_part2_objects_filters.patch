+class SearchPayload(BaseModel):
+    filter: Dict[str, Any] | None = None
+    page: int = 1
+    size: int = 50
+
+ALLOWED_USER_FIELDS = {"email", "role", "admin_vendor_id", "tenant_id"}
+ALLOWED_LICENSE_FIELDS = {"serial", "assigned_user_id", "seller_admin_id", "tenant_id"}
+
+@api_router.post("/users/search", response_model=List[User])
+async def search_users(body: SearchPayload, current_user: User = Depends(get_current_user)):
+    scope = build_scope_filter(current_user, {})
+    client = whitelist_filter(body.filter or {}, ALLOWED_USER_FIELDS)
+    q = merge_with_scope(scope, client)
+
+    page = max(1, int(body.page or 1))
+    size = min(200, max(1, int(body.size or 50)))
+    cursor = db.users.find(q).skip((page - 1) * size).limit(size)
+    items = await cursor.to_list(length=size)
+    for it in items:
+        it["id"] = str(it["_id"])
+    return items
+
